{% doc %}
  @prompt
    generate a luxury footer section with unique styles and content and designs and unique animations important , add bold text name at the end of the footer
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-footer-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    background: {{ block.settings.background_gradient }};
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .ai-luxury-footer-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: -50%;
    width: 200%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      {{ block.settings.accent_color }},
      transparent
    );
    opacity: 0.3;
  }

  .ai-luxury-footer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .ai-luxury-footer-top-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 60px;
    padding-bottom: 60px;
    border-bottom: 1px solid {{ block.settings.accent_color }};
    opacity: 0;
    transform: translateY(30px);
  }

  .ai-luxury-footer-column-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-luxury-footer-logo-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-luxury-footer-logo-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_size }}px;
    font-weight: 300;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: {{ block.settings.accent_color }};
    margin: 0;
    position: relative;
    display: inline-block;
  }

  .ai-luxury-footer-logo-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 0;
    height: 1px;
    background: {{ block.settings.accent_color }};
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-luxury-footer-tagline-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.8;
    opacity: 0.7;
    font-weight: 300;
    letter-spacing: 0.5px;
  }

  .ai-luxury-footer-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0 0 24px;
    color: {{ block.settings.accent_color }};
    position: relative;
    padding-bottom: 12px;
  }

  .ai-luxury-footer-heading-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 1px;
    background: {{ block.settings.accent_color }};
  }

  .ai-luxury-footer-links-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-luxury-footer-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 1px;
    opacity: 0.8;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
    position: relative;
  }

  .ai-luxury-footer-link-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    left: -20px;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    height: 1px;
    background: {{ block.settings.accent_color }};
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-luxury-footer-link-{{ ai_gen_id }}:hover {
    opacity: 1;
    color: {{ block.settings.accent_color }};
    transform: translateX(8px);
  }

  .ai-luxury-footer-link-{{ ai_gen_id }}:hover::before {
    width: 12px;
  }

  .ai-luxury-footer-newsletter-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-luxury-footer-input-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-luxury-footer-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid {{ block.settings.accent_color }};
    color: {{ block.settings.text_color }};
    font-size: 14px;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }

  .ai-luxury-footer-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 2px;
  }

  .ai-luxury-footer-input-{{ ai_gen_id }}:focus {
    outline: none;
    border-bottom-color: {{ block.settings.accent_color }};
  }

  .ai-luxury-footer-input-line-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: {{ block.settings.accent_color }};
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-luxury-footer-input-{{ ai_gen_id }}:focus ~ .ai-luxury-footer-input-line-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-luxury-footer-submit-{{ ai_gen_id }} {
    padding: 14px 32px;
    background: transparent;
    border: 1px solid {{ block.settings.accent_color }};
    color: {{ block.settings.accent_color }};
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    align-self: flex-start;
  }

  .ai-luxury-footer-submit-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: {{ block.settings.accent_color }};
    transition: left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }

  .ai-luxury-footer-submit-{{ ai_gen_id }}:hover {
    color: {{ block.settings.background_color }};
  }

  .ai-luxury-footer-submit-{{ ai_gen_id }}:hover::before {
    left: 0;
  }

  .ai-luxury-footer-bottom-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 40px;
    gap: 30px;
    flex-wrap: wrap;
  }

  .ai-luxury-footer-social-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border: 1px solid {{ block.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.accent_color }};
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: {{ block.settings.accent_color }};
    transform: translate(-50%, -50%);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.background_color }};
    transform: translateY(-4px);
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }}:hover::before {
    width: 100%;
    height: 100%;
  }

  .ai-luxury-footer-social-icon-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
  }

  .ai-luxury-footer-copyright-{{ ai_gen_id }} {
    font-size: 12px;
    letter-spacing: 1px;
    opacity: 0.6;
    font-weight: 300;
  }

  .ai-luxury-footer-payment-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ai-luxury-footer-payment-icon-{{ ai_gen_id }} {
    width: 40px;
    height: 26px;
    border: 1px solid {{ block.settings.accent_color }};
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .ai-luxury-footer-payment-icon-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  .ai-luxury-footer-brand-name-{{ ai_gen_id }} {
    width: 100%;
    text-align: center;
    padding-top: 30px;
    margin-top: 30px;
    border-top: 1px solid {{ block.settings.accent_color }};
    opacity: 0.3;
  }

  .ai-luxury-footer-brand-name-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_name_size }}px;
    font-weight: 700;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: {{ block.settings.accent_color }};
    margin: 0;
    position: relative;
    display: inline-block;
    background: linear-gradient(
      90deg,
      {{ block.settings.accent_color }},
      {{ block.settings.text_color }},
      {{ block.settings.accent_color }}
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media screen and (max-width: 768px) {
    .ai-luxury-footer-container-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-luxury-footer-top-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-bottom: 40px;
    }

    .ai-luxury-footer-bottom-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .ai-luxury-footer-logo-{{ ai_gen_id }} {
      font-size: {{ block.settings.logo_size | times: 0.8 }}px;
    }

    .ai-luxury-footer-brand-name-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.brand_name_size | times: 0.7 }}px;
      letter-spacing: 3px;
    }
  }
{% endstyle %}

<luxury-footer-{{ ai_gen_id }} class="ai-luxury-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-footer-container-{{ ai_gen_id }}">
    <div class="ai-luxury-footer-top-{{ ai_gen_id }}">
      <div class="ai-luxury-footer-column-{{ ai_gen_id }} ai-luxury-footer-logo-section-{{ ai_gen_id }}">
        {% if block.settings.logo_text != blank %}
          <h2 class="ai-luxury-footer-logo-{{ ai_gen_id }}">{{ block.settings.logo_text }}</h2>
        {% endif %}
        {% if block.settings.tagline != blank %}
          <p class="ai-luxury-footer-tagline-{{ ai_gen_id }}">{{ block.settings.tagline }}</p>
        {% endif %}
      </div>

      {% if block.settings.show_column_1 %}
        <div class="ai-luxury-footer-column-{{ ai_gen_id }}">
          {% if block.settings.column_1_heading != blank %}
            <h3 class="ai-luxury-footer-heading-{{ ai_gen_id }}">{{ block.settings.column_1_heading }}</h3>
          {% endif %}
          <ul class="ai-luxury-footer-links-{{ ai_gen_id }}">
            {% if block.settings.column_1_link_1_text != blank %}
              <li>
                <a href="{{ block.settings.column_1_link_1_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_1_link_1_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.column_1_link_2_text != blank %}
              <li>
                <a href="{{ block.settings.column_1_link_2_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_1_link_2_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.column_1_link_3_text != blank %}
              <li>
                <a href="{{ block.settings.column_1_link_3_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_1_link_3_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.column_1_link_4_text != blank %}
              <li>
                <a href="{{ block.settings.column_1_link_4_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_1_link_4_text }}
                </a>
              </li>
            {% endif %}
          </ul>
        </div>
      {% endif %}

      {% if block.settings.show_column_2 %}
        <div class="ai-luxury-footer-column-{{ ai_gen_id }}">
          {% if block.settings.column_2_heading != blank %}
            <h3 class="ai-luxury-footer-heading-{{ ai_gen_id }}">{{ block.settings.column_2_heading }}</h3>
          {% endif %}
          <ul class="ai-luxury-footer-links-{{ ai_gen_id }}">
            {% if block.settings.column_2_link_1_text != blank %}
              <li>
                <a href="{{ block.settings.column_2_link_1_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_2_link_1_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.column_2_link_2_text != blank %}
              <li>
                <a href="{{ block.settings.column_2_link_2_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_2_link_2_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.column_2_link_3_text != blank %}
              <li>
                <a href="{{ block.settings.column_2_link_3_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_2_link_3_text }}
                </a>
              </li>
            {% endif %}
            {% if block.settings.column_2_link_4_text != blank %}
              <li>
                <a href="{{ block.settings.column_2_link_4_url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">
                  {{ block.settings.column_2_link_4_text }}
                </a>
              </li>
            {% endif %}
          </ul>
        </div>
      {% endif %}

      {% if block.settings.show_newsletter %}
        <div class="ai-luxury-footer-column-{{ ai_gen_id }}">
          {% if block.settings.newsletter_heading != blank %}
            <h3 class="ai-luxury-footer-heading-{{ ai_gen_id }}">{{ block.settings.newsletter_heading }}</h3>
          {% endif %}
          {% form 'customer' %}
            <div class="ai-luxury-footer-newsletter-{{ ai_gen_id }}">
              {% if block.settings.newsletter_text != blank %}
                <p class="ai-luxury-footer-tagline-{{ ai_gen_id }}">{{ block.settings.newsletter_text }}</p>
              {% endif %}
              <div class="ai-luxury-footer-input-wrapper-{{ ai_gen_id }}">
                <input
                  type="email"
                  name="contact[email]"
                  class="ai-luxury-footer-input-{{ ai_gen_id }}"
                  placeholder="{{ block.settings.newsletter_placeholder }}"
                  required
                >
                <span class="ai-luxury-footer-input-line-{{ ai_gen_id }}"></span>
              </div>
              <button type="submit" class="ai-luxury-footer-submit-{{ ai_gen_id }}">
                {{ block.settings.newsletter_button }}
              </button>
            </div>
          {% endform %}
        </div>
      {% endif %}
    </div>

    <div class="ai-luxury-footer-bottom-{{ ai_gen_id }}">
      {% if block.settings.show_social %}
        <div class="ai-luxury-footer-social-{{ ai_gen_id }}">
          {% if block.settings.social_instagram != blank %}
            <a href="{{ block.settings.social_instagram }}" class="ai-luxury-footer-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener">
              <svg class="ai-luxury-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          {% endif %}
          {% if block.settings.social_facebook != blank %}
            <a href="{{ block.settings.social_facebook }}" class="ai-luxury-footer-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener">
              <svg class="ai-luxury-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
              </svg>
            </a>
          {% endif %}
          {% if block.settings.social_twitter != blank %}
            <a href="{{ block.settings.social_twitter }}" class="ai-luxury-footer-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener">
              <svg class="ai-luxury-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
              </svg>
            </a>
          {% endif %}
          {% if block.settings.social_pinterest != blank %}
            <a href="{{ block.settings.social_pinterest }}" class="ai-luxury-footer-social-link-{{ ai_gen_id }}" target="_blank" rel="noopener">
              <svg class="ai-luxury-footer-social-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M8 12c0-2.21 1.79-4 4-4 2.76 0 5 2.24 5 5 0 2.21-1.79 4-4 4-.28 0-.56-.03-.83-.08L11 20"></path>
              </svg>
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.copyright_text != blank %}
        <div class="ai-luxury-footer-copyright-{{ ai_gen_id }}">
          {{ block.settings.copyright_text }}
        </div>
      {% endif %}

      {% if block.settings.show_payment_icons %}
        <div class="ai-luxury-footer-payment-{{ ai_gen_id }}">
          <div class="ai-luxury-footer-payment-icon-{{ ai_gen_id }}">VISA</div>
          <div class="ai-luxury-footer-payment-icon-{{ ai_gen_id }}">MC</div>
          <div class="ai-luxury-footer-payment-icon-{{ ai_gen_id }}">AMEX</div>
          <div class="ai-luxury-footer-payment-icon-{{ ai_gen_id }}">PP</div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_brand_name and block.settings.brand_name != blank %}
      <div class="ai-luxury-footer-brand-name-{{ ai_gen_id }}">
        <h3 class="ai-luxury-footer-brand-name-text-{{ ai_gen_id }}">{{ block.settings.brand_name }}</h3>
      </div>
    {% endif %}
  </div>
</luxury-footer-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryFooter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.animationDelay = {{ block.settings.animation_delay }};
      }

      connectedCallback() {
        this.setupIntersectionObserver();
        this.setupLogoHover();
        this.setupBrandNameAnimation();
      }

      setupIntersectionObserver() {
        const options = {
          threshold: 0.1,
          rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.animateFooter();
              observer.unobserve(entry.target);
            }
          });
        }, options);

        observer.observe(this);
      }

      animateFooter() {
        const topSection = this.querySelector('.ai-luxury-footer-top-{{ ai_gen_id }}');
        const columns = this.querySelectorAll('.ai-luxury-footer-column-{{ ai_gen_id }}');

        setTimeout(() => {
          topSection.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
          topSection.style.opacity = '1';
          topSection.style.transform = 'translateY(0)';
        }, this.animationDelay);

        columns.forEach((column, index) => {
          setTimeout(() => {
            column.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            column.style.opacity = '1';
            column.style.transform = 'translateY(0)';
          }, this.animationDelay + 200 + (index * 100));
        });
      }

      setupLogoHover() {
        const logo = this.querySelector('.ai-luxury-footer-logo-{{ ai_gen_id }}');
        if (logo) {
          logo.addEventListener('mouseenter', () => {
            logo.style.transition = 'letter-spacing 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
            logo.style.letterSpacing = '6px';
          });

          logo.addEventListener('mouseleave', () => {
            logo.style.letterSpacing = '4px';
          });
        }
      }

      setupBrandNameAnimation() {
        const brandName = this.querySelector('.ai-luxury-footer-brand-name-text-{{ ai_gen_id }}');
        if (brandName) {
          let position = 0;
          setInterval(() => {
            position += 1;
            brandName.style.backgroundPosition = position + '% center';
          }, 30);
        }
      }
    }

    customElements.define('luxury-footer-{{ ai_gen_id }}', LuxuryFooter{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Luxury footer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 40,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
